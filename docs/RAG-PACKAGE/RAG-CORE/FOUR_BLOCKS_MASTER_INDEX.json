  "routing_rules": {
    "description": "When a query arrives, the RAG system uses these rules to determine which silo and file to retrieve from first.",
    "rules": [
      {
        "query_type": "Active emotional disturbance",
        "signals": [
          "I feel",
          "I am angry",
          "I am anxious",
          "I am depressed",
          "I feel guilty",
          "I can't stand",
          "what if",
          "should",
          "I'm worthless"
        ],
        "primary_silo": "behavioral_library",
        "secondary_silo": "constitution",
        "tertiary_silo": "course_library",
        "routing_note": "Retrieve formula, validation, mapping, and reframe chunks. Cross-check constitution for anti-drift compliance."
      },
      {
        "query_type": "Conceptual or educational query",
        "signals": [
          "what is",
          "how does",
          "explain",
          "teach me",
          "what does it mean",
          "why do I",
          "how do formulas work"
        ],
        "primary_silo": "course_library",
