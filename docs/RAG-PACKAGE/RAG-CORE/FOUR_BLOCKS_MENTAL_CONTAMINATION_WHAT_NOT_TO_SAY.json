{
  "document_type": "negative_guidance_addendum",
  "title": "Four Blocks RAG Addendum — Mental Contamination What Not to Say Blueprint",
  "subtitle": "Forbidden Response Patterns for Mental Contamination and All Four Emotions",
  "version": "1.0",
  "category": "cognitive_framework",
  "audience": "developer",
  "sections": [
    {
      "id": "MCNG_S1",
      "title": "Purpose of Negative Guidance",
      "purpose": "Define forbidden response patterns that violate Dr. Parr’s Four Blocks logic, deterministic emotional reasoning, and RAG fidelity and safety.",
      "failure_condition": "If any forbidden pattern appears, the response is invalid."
    },
    {
      "id": "MCNG_S2",
      "title": "Global Prohibitions — All Emotions",
      "prohibited_categories": [
        {
          "id": "MCNG_S2_A",
          "category": "Emotional Invalidation",
          "forbidden_phrases": [
            "You shouldn’t feel this way.",
            "Just calm down.",
            "It’s not a big deal.",
            "Others have it worse."
          ],
          "reason": "Dismisses emotion instead of identifying mental contamination."
        },
        {
          "id": "MCNG_S2_B",
          "category": "Pure Reassurance Without Cognitive Structure",
          "forbidden_phrases": [
            "Everything will be okay.",
            "You’ll get through this.",
            "Stay positive."
          ],
          "reason": "Four Blocks requires mechanism → shift → relief, not optimism."
        },
        {
          "id": "MCNG_S2_C",
          "category": "Advice Before Contamination Is Identified",
          "forbidden_approaches": [
            "Breathing techniques",
            "Mindfulness",
            "Distraction",
            "Journaling",
            "Exercise prescriptions"
          ],
          "reason": "These regulate symptoms but do not remove contamination, which is the primary cause of emotional intensity."
        },
        {
          "id": "MCNG_S2_D",
          "category": "Agreement With Distorted Thinking",
          "forbidden_validations": [
            "Catastrophes",
            "Worthlessness",
            "Absolute hopelessness",
            "Moral perfectionism",
            "Intolerance beliefs"
          ],
          "reason": "Reinforces contamination, deepening emotional disturbance."
        },
        {
          "id": "MCNG_S2_E",
          "category": "Harsh Cognitive Confrontation",
          "forbidden_tones": [
            "Debate",
            "Argument",
            "That’s irrational.",
            "You’re wrong."
          ],
          "reason": "Four Blocks uses calm separation, not adversarial correction."
        }
      ]
    },
    {
      "id": "MCNG_S3",
      "title": "Mental Contamination-Specific Prohibitions",
      "prohibitions": [
        {
          "prohibition": "Skip naming the contamination",
          "example_violation": "Giving coping advice without identifying distortion.",
          "why_invalid": "Breaks core Four Blocks sequence."
        },
        {
          "prohibition": "Treat contamination as reality",
          "example_violations": [
            "Yes, this is a disaster.",
            "You really did ruin everything.",
            "You are a bad person."
          ],
          "why_invalid": "Collapses reality vs. distortion separation, the central therapeutic move."
        },
        {
          "prohibition": "Jump directly to emotion regulation",
          "example_violations": [
            "Here’s how to calm anxiety…",
            "Try to relax when angry…"
          ],
          "why_invalid": "Four Blocks always targets thinking before feeling."
        }
      ]
    },
    {
      "id": "MCNG_S4",
      "title": "Emotion-Specific What Not to Say",
      "emotions": [
        {
          "emotion": "depression",
          "forbidden_phrases": [
            "You just need to think positive.",
            "Focus on gratitude.",
            "Everything happens for a reason.",
            "Time heals all wounds."
          ],
          "reason": "These ignore the rigid Need, which is the true depressive driver.",
          "also_forbidden": [
            "Agreeing the future is hopeless",
            "Reinforcing helplessness"
          ]
        },
        {
          "emotion": "anger",
          "forbidden_phrases": [
            "You shouldn’t be angry.",
            "Forgive them.",
            "Let it go.",
            "They didn’t mean it."
          ],
          "reason": "These invalidate moral perception instead of softening the rigid Should.",
          "also_forbidden": [
            "Siding against the user’s values",
            "Encouraging revenge or blame escalation"
          ]
        },
        {
          "emotion": "guilt",
          "forbidden_phrases": [
            "It’s not your fault (when responsibility exists).",
            "Just forgive yourself.",
            "You did nothing wrong."
          ],
          "reason": "Four Blocks requires keeping W1 honesty while removing W2 worthlessness. Erasing responsibility breaks the model.",
          "also_forbidden": [
            "Confirming the user is bad or unworthy"
          ]
        },
        {
          "emotion": "anxiety",
          "forbidden_phrases": [
            "Don’t worry.",
            "Stop thinking about it.",
            "Everything will work out.",
            "You’re overreacting."
          ],
          "reason": "These fail to soften W1, AW, ACSI and instead create suppression.",
          "also_forbidden": [
            "Confirming catastrophe likelihood",
            "Agreeing the user can’t handle it"
          ]
        }
      ]
    },
    {
      "id": "MCNG_S5",
      "title": "RAG Ingestion Rules for Negative Guidance",
      "global_chunks": [
        "MC_FORBIDDEN_GLOBAL_INVALIDATION",
        "MC_FORBIDDEN_REASSURANCE",
        "MC_FORBIDDEN_PREMATURE_COPING",
        "MC_FORBIDDEN_DISTORTION_AGREEMENT",
        "MC_FORBIDDEN_HARSH_CONFRONTATION"
      ],
      "emotion_linked_chunks": [
        "DEP_FORBIDDEN_PHRASES",
        "ANG_FORBIDDEN_PHRASES",
        "GUILT_FORBIDDEN_PHRASES",
        "ANX_FORBIDDEN_PHRASES"
      ]
    },
    {
      "id": "MCNG_S6",
      "title": "Retrieval Enforcement",
      "process": "During response generation, system must check: Does any sentence match a forbidden pattern?",
      "if_yes": "Response must be re-rendered before output.",
      "purpose": "Acts as a therapeutic safety filter."
    },
    {
      "id": "MCNG_S7",
      "title": "Success Criteria",
      "criteria": [
        "No emotional invalidation",
        "No reassurance without mechanism",
        "No skipped contamination step",
        "No distortion agreement",
        "No responsibility erasure (guilt)",
        "No moral invalidation (anger)",
        "No catastrophe reinforcement (anxiety)",
        "No hopelessness confirmation (depression)"
      ],
      "failure_condition": "Response is Four Blocks invalid."
    }
  ]
}